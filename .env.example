# The active browser-only guided sizing application requires no runtime
# environment variables, AI keys, model paths, dataset credentials, or API URL.
#
# Vercel deployment credentials belong in protected GitHub environments:
# - variable: VERCEL_TEAM_ID
# - variable: VERCEL_PROJECT_ID
# - production-only variable: VERCEL_PRODUCTION_URL
# - secret: VERCEL_TOKEN
#
